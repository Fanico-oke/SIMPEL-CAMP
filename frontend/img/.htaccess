# Prevent PHP execution in upload directories
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule \.php$ - [F,L]
</IfModule>

# Only allow image files
<FilesMatch "\.(?!jpg|jpeg|png|gif|webp|svg|ico)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
